# ─── HuggingFace Token ─────────────────────────────────────────────────────────
# Get your token from: https://huggingface.co/settings/tokens
# Needs "Make calls to the serverless Inference API" permission
HF_TOKEN=hf_your_token_here

# ─── Model (optional — defaults to Qwen2.5-72B-Instruct) ──────────────────────
# Other options: "meta-llama/Llama-3.3-70B-Instruct", "mistralai/Mistral-7B-Instruct-v0.3"
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# ─── API Base URL (optional — do not change unless using a different provider) ──
API_BASE_URL=https://router.huggingface.co/v1

# ─── Environment Server URL (optional — only change if not running locally) ─────
ENV_URL=http://localhost:7860
